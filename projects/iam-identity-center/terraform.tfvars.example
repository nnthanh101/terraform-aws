# terraform.tfvars.example — IAM Identity Center project
# Copy to terraform.tfvars and customize for your environment.
#
# Source: app.terraform.io/oceansoft/iam-identity-center/aws ~> 1.2 (registry-pinned)
# For local module development only, change source in main.tf to: "../../modules/iam-identity-center"
#
# Init: terraform init -backend-config="bucket=${ACCOUNT_ID}-tfstate-${REGION}" -backend-config="region=ap-southeast-2"
# Or:   MODULE=iam-identity-center bash scripts/deploy-init.sh
#
# Required env vars:
#   AWS_PROFILE=aws-sandbox  (or export AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY)

# SSO region — where IAM Identity Center is enabled (any region for account-level SSO)
sso_region = "ap-southeast-2"

# Multi-account IDs (optional — omit for single-account sandbox)
# security_account_id = "222222222222"
# workload_account_id = "333333333333"

# FOCUS 1.2+ FinOps tags — override per environment
default_tags = {
  CostCenter         = "platform"
  Project            = "iam-identity-center"
  Environment        = "production"   # Change per environment: sandbox|staging|production
  ServiceName        = "sso"
  DataClassification = "confidential" # Change per environment: internal|confidential|restricted
  ManagedBy          = "terraform"
  Owner              = "platform-team"
  Team               = "cloudops"
}
